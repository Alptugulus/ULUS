{
  "name": "ulus-media",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/check-jsx.mjs && node scripts/dev.mjs",
    "dev:restart": "ULUS_DEV_RESTART=1 node scripts/check-jsx.mjs && node scripts/dev.mjs",
    "dev:attach": "node scripts/check-jsx.mjs && node scripts/dev.mjs",
    "dev:reset": "ULUS_DEV_FORCE=1 node scripts/check-jsx.mjs && node scripts/reset-dev.mjs",
    "dev:webpack": "node scripts/check-jsx.mjs && ULUS_WEBPACK=1 next dev -H 127.0.0.1",
    "build": "node scripts/check-jsx.mjs && next build",
    "start": "next start -H 127.0.0.1",
    "lint": "next lint",
    "check:jsx": "node scripts/check-jsx.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "next": "^15.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
